# ============================================================================
# MINDLEDGER - Variáveis de Ambiente (Exemplo)
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env
# Ou use o script interativo:
#   ./setup-env.sh
# ============================================================================

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DB_HOST=db
DB_PORT=39102
DB_NAME=mindledger_db
DB_USER=mindledger_user
DB_PASSWORD=your_secure_db_password_here

# ============================================================================
# DJANGO (Backend API)
# ============================================================================
# Gerar com: python -c "import secrets; chars='abcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*(-_=+)'; print(''.join(secrets.choice(chars) for _ in range(50)))"
SECRET_KEY=your-50-character-random-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:39101,http://127.0.0.1:39101

# ============================================================================
# DJANGO SUPERUSER
# ============================================================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=your_secure_superuser_password_here

# ============================================================================
# ENCRYPTION
# ============================================================================
# CRÍTICO: Nunca altere esta chave após o primeiro uso.
# Todos os dados criptografados no banco ficarão ilegíveis se a chave mudar.
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-44-character-fernet-base64-key-here=

# ============================================================================
# LOGGING
# ============================================================================
LOG_FORMAT=json
LOG_LEVEL=INFO

# ============================================================================
# APPLICATION PORTS
# ============================================================================
API_PORT=39100
FRONTEND_PORT=39101

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
VITE_API_BASE_URL=http://localhost:39100

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
BACKUP_DIR=./backups

# ============================================================================
# MinIO / S3 Object Storage
# ============================================================================
MINIO_ROOT_USER=mindledger
MINIO_ROOT_PASSWORD=your_secure_minio_password_here
MINIO_BUCKET_NAME=mindledger
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=localhost:39105
MINIO_USE_SSL=false
MINIO_PORT=39105
MINIO_CONSOLE_PORT=39106

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
ENABLE_DEBUG_TOOLBAR=False
SHOW_SQL_QUERIES=False
