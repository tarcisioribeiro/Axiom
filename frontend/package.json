    "jest-axe": "10.0.0",
    "lint-staged": "15.5.2",
    "postcss": "8.5.14",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.6.14",
    "storybook": "8.6.18",
    "tailwindcss": "3.4.18",
    "terser": "5.46.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.1",
    "vite": "6.4.2",
    "vite-plugin-compression": "0.5.1",
    "vitest": "3.2.4"
  }
}
