# URL base da API (usado como fallback quando acessando via localhost)
# A URL é calculada dinamicamente baseada no hostname quando acessado via IP de rede
VITE_API_BASE_URL=http://localhost:39100

# Porta da API (usada para calcular URL dinâmica quando acessando via IP)
VITE_API_PORT=39100

# Fase do ambiente: "staging" | "production"
# Em desenvolvimento local, pode omitir (cai em "development" automaticamente)
# A faixa diagonal de ambiente NÃO aparece quando VITE_APP_ENV=production
VITE_APP_ENV=staging
